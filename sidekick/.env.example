# --- Gemini (the eyes + brain) — REQUIRED ---
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- SLNG (the ears + mouth) — slng.ai ---
# Optional. Without it, Sidekick runs in --text mode and won't speak.
SLNG_API_KEY=
SLNG_STT_MODEL=slng/deepgram/nova:3-en
SLNG_TTS_MODEL=slng/deepgram/aura:2-en
SLNG_TTS_VOICE=aura-2-theia-en

# --- Attio (the data) — REST API, REQUIRED for lookups ---
# Uses Attio's REST API ("list records" on the object below). The hosted MCP needs OAuth,
# which a read-only API key can't satisfy, so we use REST.
ATTIO_API_KEY=
# ATTIO_OBJECT=companies
# Attribute slugs in YOUR workspace:
# ATTIO_ATTR_OUTBOUND=outbound   # a 'select'; option titled "LinkedIn" = has LinkedIn outbound
# ATTIO_ATTR_STATUS=status       # a 'status'; e.g. "Interested" / "Connecting"

# --- Capture / behavior ---
# Capture a specific display id to avoid filming Sidekick's own terminal (run `screenshot --list`).
CAPTURE_DISPLAY=
# Microphone input device for sox (exact CoreAudio name). Empty = system default.
# MIC_DEVICE="Wireless Mic Rx"
# Override the trigger phrases (pipe-separated), e.g. "i forgot|remind me|i can't remember"
# SIDEKICK_TRIGGERS=
